# ChoreTracker application settings
APP_NAME=ChoreTracker
APP_ENV=development

# Non-standard host ports help avoid collisions with other local projects.
API_HOST=127.0.0.1
API_PORT=8110
POSTGRES_HOST_PORT=55410
FRONTEND_PORT=51810

# PostgreSQL application database
POSTGRES_DB=choretracker
POSTGRES_USER=choretracker_app
POSTGRES_PASSWORD=development-only-password
POSTGRES_HOST=127.0.0.1
POSTGRES_CONTAINER_PORT=5432
